  "@type": "schema:Dataset",

  "dc:title": "COVID-19 Open Research Dataset Challenge (CORD-19)",

  "dc:creator": [
    "Semantic Scholar team, Allen Institute for AI",
    "COVID-19 Open Research Dataset (CORD-19) collaborators"
  ],

  "dc:subject": [
